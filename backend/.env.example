# Copy to .env and set your key
OPENROUTER_API_KEY=sk-or-...

# Logging — set to DEBUG to see per-chunk stream traces in the terminal
# LOG_LEVEL=DEBUG

# Optional: override SQLite path (default: ./data/assistant.db)
# ASSISTANT_DB_PATH=./data/assistant.db

# Models — any OpenRouter model ID in provider/model-name format
# See https://openrouter.ai/models for available models
# CLASSIFIER_MODEL=anthropic/claude-haiku-4.5
# CLASSIFIER_MAX_TOKENS=1024
# AGENT_MODEL=anthropic/claude-sonnet-4.6
# AGENT_MAX_TOKENS=16000

# Reasoning — controls extended thinking for agent models
# For claude-sonnet-4.6 and newer Anthropic models: {"effort": "high"}
# For claude-3.7-sonnet:thinking (older style):     {"max_tokens": 10000}
# For OpenAI o-series:                              {"effort": "high"}
# To disable reasoning entirely:                    {}
# AGENT_REASONING={"enabled": true}
