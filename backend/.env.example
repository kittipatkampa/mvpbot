# Logging level: DEBUG or INFO (default: INFO)
LOG_LEVEL=INFO

# Copy to .env and fill in your values
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override SQLite path (default: ./data/assistant.db)
# ASSISTANT_DB_PATH=./data/assistant.db

# ----------------------------
# OpenRouter model configuration
# ----------------------------
# Classifier (fast/cheap model for intent routing)
# CLASSIFIER_MODEL=anthropic/claude-haiku-4-5
# CLASSIFIER_MAX_TOKENS=1024

# Agent model — any model from https://openrouter.ai/models
# AGENT_MODEL=anthropic/claude-sonnet-4-5
# AGENT_MAX_TOKENS=16000

# Reasoning / thinking tokens (JSON dict or leave unset to disable)
# Anthropic models:  AGENT_REASONING={"enabled": true}
# OpenAI o-series:   AGENT_REASONING={"effort": "medium"}
# Qwen QwQ:          (omit AGENT_REASONING — Qwen reasons natively, the param causes 400)
# Disable:           comment out or set to null
# AGENT_REASONING={"enabled": true}

# Langfuse observability — get keys from https://cloud.langfuse.com (or your self-hosted instance)
# Leave unset to disable tracing entirely.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com  # default; change for self-hosted or US region
