# Copy to .env and set your key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override SQLite path (default: ./data/assistant.db)
# ASSISTANT_DB_PATH=./data/assistant.db

# Langfuse observability — get keys from https://cloud.langfuse.com (or your self-hosted instance)
# Leave unset to disable tracing entirely.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com  # default; change for self-hosted or US region
