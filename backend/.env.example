# Logging level: DEBUG or INFO (default: INFO)
LOG_LEVEL=INFO

# Copy to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override SQLite path (default: ./data/assistant.db)
# ASSISTANT_DB_PATH=./data/assistant.db

# ----------------------------
# Anthropic models configuration
# ----------------------------
# Classifier (fast/cheap model for intent routing)
# CLASSIFIER_MODEL=claude-haiku-4-5
# CLASSIFIER_MAX_TOKENS=1024

# Agent (full reasoning model)
# AGENT_MODEL=claude-sonnet-4-20250514
# AGENT_MAX_TOKENS=16000
# AGENT_THINKING_BUDGET_TOKENS=10000

# Arize Phoenix observability — leave empty to disable tracing
# Self-hosted: run `python -m phoenix.server.main` then set endpoint below
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
# Cloud (https://app.phoenix.arize.com):
# Usually in the format of https://app.phoenix.arize.com/s/{your-space-name}/v1/traces
# PHOENIX_COLLECTOR_ENDPOINT=
# Go to https://app.phoenix.arize.com/s/{your-space-name} → Settings → API Keys
# PHOENIX_API_KEY=
